# My .bashrc file
# Check out all my dotfile on https://github.com/lap00zza/dotfiles

## Directory Navigation ##
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

## GIT ##
alias g="git"
alias gs="git status"

## LS ##
alias ll="ls -alh"
alias ls="ls --color=auto"

## Useful Locations ##
vscode="/e/Program Files/Microsoft VS Code/bin"
ffmpeg="/d/ffmpeg/bin"
PATH=$PATH:$vscode:$ffmpeg
